{
  "name": "capturflow",
  "version": "0.1.1",
  "description": "Cross-browser screen + webcam recording with Document PiP overlay, custom UI, pause/resume, and chunked upload",
  "keywords": [
    "screen-recording",
    "picture-in-picture",
    "pip",
    "webcam",
    "getDisplayMedia",
    "mediarecorder",
    "composite-recording",
    "webm",
    "chunked-upload"
  ],
  "author": "Tushar Jadhav (https://github.com/TusharJadhav0306)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TusharJadhav0306/capturflow.git"
  },
  "homepage": "https://github.com/TusharJadhav0306/capturflow#readme",
  "bugs": {
    "url": "https://github.com/TusharJadhav0306/capturflow/issues"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.esm.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "GUIDE.md",
    "TESTING.md"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "node --test \"test/**/*.test.mjs\"",
    "prepublishOnly": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "fix-webm-duration": "^1.0.6"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
